// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  name          String?
  role          String    @default("FARMER") // FARMER, EXPERT, ADMIN
  language      String    @default("English")
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Farmer relations
  questions     Question[] @relation("FarmerQuestions")
  subscriptions Subscription[]
  reports       DiseaseReport[]

  // Expert relations
  expertAdvisories Advisory[]
  expertReplies    Question[] @relation("ExpertReplies")
}

model Advisory {
  id          String   @id @default(uuid())
  title       String
  content     String
  type        String   // TEXT, AUDIO, IMAGE
  mediaUrl    String?
  category    String   // PEST, WEATHER, CROP, FERTILIZER
  expertId    String
  expert      User     @relation(fields: [expertId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id          String   @id @default(uuid())
  content     String
  voiceUrl    String?
  imageUrl    String?
  status      String   @default("PENDING") // PENDING, REPLIED, ESCALATED
  farmerId    String
  farmer      User     @relation("FarmerQuestions", fields: [farmerId], references: [id])
  expertId    String?
  expert      User?    @relation("ExpertReplies", fields: [expertId], references: [id])
  replies     Reply[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reply {
  id          String   @id @default(uuid())
  content     String
  voiceUrl    String?
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  createdAt   DateTime @default(now())
}

model DiseaseReport {
  id          String   @id @default(uuid())
  imageUrl    String
  description String?
  diagnosis   String?
  status      String   @default("PENDING")
  farmerId    String
  farmer      User     @relation(fields: [farmerId], references: [id])
  createdAt   DateTime @default(now())
}

model Subscription {
  id          String   @id @default(uuid())
  planName    String   // FREE, PREMIUM
  status      String   @default("ACTIVE")
  paymentId   String?
  amount      Float
  provider    String?  // AIRTEL, TNM
  farmerId    String
  farmer      User     @relation(fields: [farmerId], references: [id])
  startDate   DateTime @default(now())
  endDate     DateTime
}
